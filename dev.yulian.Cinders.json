{
    "id": "dev.yulian.Cinders",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "cinders",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--share=network",
        "--talk-name=org.kde.StatusNotifierWatcher",
        "--talk-name=org.a11y.Bus"
    ],
    "modules": [
        {
            "name": "blueprint",
            "buildsystem": "meson",
            "cleanup": ["*"],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/blueprint-compiler/0.18/blueprint-compiler-0.18.0.tar.xz",
                    "sha256": "4142b9017151a347ccdc2907ac033b18508363476b44a76d0420b4af420bd866"
                }
            ]
        },
        {
            "name": "libportal",
            "buildsystem": "meson",
            "config-opts": [
                "-Ddocs=false",
                "-Dvapi=false",
                "-Dbackend-gtk4=enabled"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/flatpak/libportal/releases/download/0.9.1/libportal-0.9.1.tar.xz",
                    "sha256": "de801ee349ed3c255a9af3c01b1a401fab5b3fc1c35eb2fd7dfb35d4b8194d7f"
                }
            ]
        },
        {
            "name": "libayatana-appindicator-glib",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DENABLE_TESTS=OFF"
            ],
            "cleanup": [
                "/include",
                "/share/doc",
                "/share/vala"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/AyatanaIndicators/libayatana-appindicator-glib.git",
                    "tag": "2.0.3",
                    "commit": "4fa65d8ce1a7f1a1f22cefe3d5bdd47667f188d0"
                }
            ]
        },
        {
            "name": "cinders",
            "buildsystem": "meson",
            "builddir": true,
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
