#!@GJS@ -m

import { exit, programArgs, programInvocationName } from "system";
import Gio from "gi://Gio";
import { setConsoleLogDomain } from "console";

imports.package.init({
    name: "@app_id@",
    version: "@version@",
    prefix: "@prefix@",
    libdir: "@libdir@",
    datadir: "@datadir@",
});
setConsoleLogDomain(pkg.name);

const resource = Gio.resource_load(
    "@datadir@/@app_id@/@app_id@.src.gresource",
);
Gio.resources_register(resource);

const module = await import("resource://dev/yulian/Cinders@profile@/main.js");
const exitCode = await module.main([programInvocationName, ...programArgs]);
exit(exitCode);
